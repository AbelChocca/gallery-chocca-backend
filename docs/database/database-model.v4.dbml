  PENDING
  ACCEPTED
  REJECTED
  ERROR
}

Enum production_order_reason {
    LOW_STOCK
    CUSTOMER_ORDER
    NEW_COLLECTION
}

Enum stock_transfer_status {

CREATED

SENT

RECEIVED

