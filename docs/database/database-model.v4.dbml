  INTERNAL_SALE
  EXPORT
  INTERNAL_ADVANCE
  NON_DOMICILED_SALE
  DETRACTION
  PASSENGER_TRANSPORT_DETRACTION
  CARGO_TRANSPORT_DETRACTION
  HYDROBIOLOGICAL_DETRACTION
  PERCEPTION
  TAX_FREE
}

